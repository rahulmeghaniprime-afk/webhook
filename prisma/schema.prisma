generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_7GbdHOcmB8SQ@ep-odd-rice-ahg1jbiz-pooler.c-3.us-east-1.aws.neon.tech/neondb?channel_binding=require&sslmode=require"
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}


model AppData {
  id                  String    @id @default(cuid())
  shop                String
  key                 String
  value               String

  @@index([shop], name: "appdata_shop_idx")
}